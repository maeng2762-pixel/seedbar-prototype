# Server
PORT=3001
HOST=127.0.0.1
DATABASE_PATH=./backend/db/seedbar.sqlite
JWT_SECRET=replace_with_a_long_random_secret_32_plus_chars
JWT_EXPIRES_IN=30d
DEV_AUTH_SEED=true
VITE_API_BASE_URL=https://your-backend-domain.com

# OpenAI (server-only)
OPENAI_API_KEY=your_openai_api_key
OPENAI_LOW_COST_MODEL=gpt-4.1-mini
OPENAI_HIGH_QUALITY_MODEL=gpt-4.1

# Spotify (server-only)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube Data API (server-only)
YOUTUBE_API_KEY=your_youtube_api_key
